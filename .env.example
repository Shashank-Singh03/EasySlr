# Copy to `.env` and fill in. `.env` is gitignored; this template is committed.
# The schema that validates these lives in src/env.js.

# NextAuth — signs JWT session tokens. Generate one with:  npx auth secret
AUTH_SECRET=""

# Postgres connection string. Matches docker-compose.yml defaults for local dev.
DATABASE_URL="postgresql://postgres:password@localhost:5433/easyslr"
